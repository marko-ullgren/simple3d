# Octahedron — regular, 6 vertices on the axes at radius 90
# 6 points, 8 triangular faces

points
  90   0   0
 -90   0   0
   0  90   0
   0 -90   0
   0   0  90
   0   0 -90

faces
# Back hemisphere (z > 0, away from viewer)
0 2 4
2 1 4
1 3 4
3 0 4
# Front hemisphere (z < 0, toward viewer)
0 5 2
2 5 1
1 5 3
3 5 0
