# Cube body
# 8 points, 6 quad faces
# Coordinate system: x right, y up, z away from viewer

points
-90  90 -90
 90  90 -90
 90 -90 -90
-90 -90 -90
-90  90  90
 90  90  90
 90 -90  90
-90 -90  90

faces
# front  (z=-90, normal -z, toward viewer)
0 1 2 3
# back   (z=+90, normal +z, away from viewer)
4 7 6 5
# left   (x=-90, normal -x)
0 3 7 4
# right  (x=+90, normal +x)
1 5 6 2
# top    (y=+90, normal +y)
0 4 5 1
# bottom (y=-90, normal -y)
2 6 7 3
